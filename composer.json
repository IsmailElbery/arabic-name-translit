{
    "name": "ismailelbery/arabic-name-translit",
    "description": "Name-aware transliteration of Arabic personal names into Latin script — transliterates, never translates.",
    "type": "library",
    "keywords": ["arabic", "transliteration", "names", "icao", "doc9303", "laravel", "phonetic"],
    "license": "MIT",
    "authors": [
        {
            "name": "Ismail",
            "email": "ismail.bery@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "friendsofphp/php-cs-fixer": "^3.49"
    },
    "autoload": {
        "psr-4": {
            "Ismail\\NameTranslit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ismail\\NameTranslit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ismail\\NameTranslit\\Laravel\\NameTranslitServiceProvider"
            ],
            "aliases": {
                "Transliterator": "Ismail\\NameTranslit\\Laravel\\Facades\\Transliterator"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
